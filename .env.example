# Router auth — clients must send this in x-api-key
ROUTER_SECRET_KEY=replace-me

# Provider keys (only set the ones you need)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Mongo
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=model_router

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
